{
  "name": "qoe-web-player",
  "version": "1.0.0",
  "description": "StreamApp web video player",
  "private": true,
  "scripts": {
    "dev": "vite",
    "build": "tsc && vite build",
    "preview": "vite preview",
    "lint": "eslint . --ext ts,tsx --report-unused-disable-directives --max-warnings 0",
    "test": "cross-env ALLURE_RESULTS_DIR=allure-results/unit vitest run --run",
    "test:watch": "vitest",
    "test:allure": "cross-env ALLURE_RESULTS_DIR=allure-results/unit vitest run --run",
    "clean:reports": "node scripts/clean-reports.mjs all",
    "clean:reports:bat": "node scripts/clean-reports.mjs bat",
    "clean:reports:smoke": "node scripts/clean-reports.mjs smoke",
    "clean:reports:e2e": "node scripts/clean-reports.mjs e2e",
    "clean:reports:unit": "node scripts/clean-reports.mjs unit",
    "e2e:install": "playwright install --with-deps chromium",
    "e2e:debug": "cross-env PLAYWRIGHT_BASE_URL=http://localhost:3000 playwright test --project=chromium --debug",
    "e2e:ui": "cross-env PLAYWRIGHT_BASE_URL=http://localhost:3000 playwright test --ui",
    "e2e:bat": "cross-env PLAYWRIGHT_STAGE=bat playwright test --project=chromium --grep @BAT",
    "e2e:smoke": "cross-env PLAYWRIGHT_STAGE=smoke playwright test --project=chromium --grep @Smoke",
    "e2e:docker": "cross-env PLAYWRIGHT_BASE_URL=http://localhost:3000 cross-env PLAYWRIGHT_STAGE=e2e playwright test --project=chromium",
    "e2e:bat:headed": "cross-env PLAYWRIGHT_BASE_URL=http://localhost:3000 cross-env PLAYWRIGHT_STAGE=bat playwright test --project=chromium --grep @BAT --headed",
    "e2e:smoke:headed": "cross-env PLAYWRIGHT_STAGE=smoke playwright test --project=chromium --grep @Smoke --headed",
    "e2e:docker:headed": "cross-env PLAYWRIGHT_BASE_URL=http://localhost:3000 cross-env PLAYWRIGHT_STAGE=e2e playwright test --project=chromium --headed",
    "e2e:bat:headed:clean": "npm run clean:reports:bat && npm run e2e:bat:headed",
    "e2e:smoke:headed:clean": "npm run clean:reports:smoke && npm run e2e:smoke:headed",
    "e2e:docker:headed:clean": "npm run clean:reports:e2e && npm run e2e:docker:headed",
    "e2e:bat:clean": "npm run clean:reports:bat && npm run e2e:bat",
    "e2e:smoke:clean": "npm run clean:reports:smoke && npm run e2e:smoke",
    "e2e:docker:clean": "npm run clean:reports:e2e && npm run e2e:docker",
    "allure:unit": "allure generate allure-results/unit --clean -o allure-report/unit",
    "allure:bat": "allure generate allure-results/bat --clean -o allure-report/bat",
    "allure:smoke": "allure generate allure-results/smoke --clean -o allure-report/smoke",
    "allure:e2e": "allure generate allure-results/e2e --clean -o allure-report/e2e",
    "allure:serve:unit": "allure serve allure-results/unit --port 5050",
    "allure:serve:bat": "allure serve allure-results/bat --port 5051",
    "allure:serve:smoke": "allure serve allure-results/smoke --port 5052",
    "report:bat": "npm run e2e:bat && npm run allure:bat",
    "report:smoke": "npm run e2e:smoke && npm run allure:smoke",
    "report": "playwright show-report playwright-report/e2e"
  },
  "dependencies": {
    "@newrelic/browser-agent": "^1.291.1",
    "axios": "^1.6.2",
    "hls.js": "^1.4.12",
    "react": "^18.2.0",
    "react-dom": "^18.2.0"
  },
  "devDependencies": {
    "@playwright/test": "^1.49.0",
    "@types/react": "^18.2.43",
    "@types/react-dom": "^18.2.17",
    "@typescript-eslint/eslint-plugin": "^8.46.0",
    "@typescript-eslint/parser": "^8.46.0",
    "@vitejs/plugin-react": "^4.5.2",
    "allure-playwright": "^3.7.1",
    "allure-vitest": "^3.7.1",
    "cross-env": "^10.1.0",
    "eslint": "^8.57.0",
    "eslint-plugin-react-hooks": "^4.6.0",
    "eslint-plugin-react-refresh": "^0.4.5",
    "jsdom": "^24.0.0",
    "typescript": "^5.2.2",
    "vite": "^6.4.3",
    "vitest": "^3.2.6"
  }
}
