# ─────────────────────────────────────────────────────────────────────────────
# QoE Workshop — environment template.
# Copy to `.env` (gitignored) and fill in the values you actually have.
# Anything left blank/commented makes the corresponding agent stay disabled.
# ─────────────────────────────────────────────────────────────────────────────

# === A. Backend Java APM ────────────────────────────────────────────────────
# `docker compose up backend` reads these. NEWRELIC_ENABLED must be `true`
# AND NEWRELIC_LICENSE_KEY must be non-empty for the agent to attach (see
# backend-api/docker-entrypoint.sh).

NEWRELIC_ENABLED=true
# 40-char "INGEST - LICENSE" key from NR UI → Administration → API keys
NEWRELIC_LICENSE_KEY=
# What the app shows up as in NR APM
NEWRELIC_APP_NAME=QoE API (Workshop)


# === B. Web Browser RUM ─────────────────────────────────────────────────────
# Vite reads VITE_* vars at *build* time and inlines them into the bundle, so
# rebuild the web-player after changing these (npm run build / docker-compose
# build web-player).
#
# All three values come from the JS snippet NR generates when you create a
# Browser app: NR UI → Add data → Browser monitoring → Copy/paste JS code.
# Look inside the snippet for NREUM.loader_config and NREUM.info.

# Browser license sub-key (different from the APM ingest key above; e.g. "NRJS-...")
VITE_NEWRELIC_LICENSE_KEY=
# Numeric application ID (from NREUM.loader_config.applicationID / info.applicationID)
VITE_NEWRELIC_APPLICATION_ID=
# Numeric account ID (from NREUM.loader_config.accountID)
VITE_NEWRELIC_ACCOUNT_ID=
# Optional — defaults to accountID when blank (single-account setups)
VITE_NEWRELIC_TRUST_KEY=
# Optional — defaults to applicationID when blank
VITE_NEWRELIC_AGENT_ID=


# === C. Android Mobile APM (only used at gradle build time) ─────────────────
# Build with:  ./gradlew :app:assembleDebug -Pnewrelic.token=$NEW_RELIC_MOBILE_TOKEN
# This is a *separate* token type from the Browser/APM keys above; generate it
# at NR UI → Add data → Mobile → Android.
NEW_RELIC_MOBILE_TOKEN=
